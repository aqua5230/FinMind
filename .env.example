# FinMind API token for authenticated market data access
FINMIND_TOKEN=your_finmind_token

# Claude API key used to generate report summaries
CLAUDE_API_KEY=your_claude_api_key

# Set to true to enable debug logging
DEBUG=false

# Base URL for FinMind API requests
SERVICE__API_BASE_URL=https://api.finmindtrade.com/api/v4/data

# HTTP timeout in seconds for upstream API calls
SERVICE__TIMEOUT=30

# Retry count for transient upstream failures
SERVICE__RETRY=3

# Claude model name used for report generation
GENERATION__MODEL_NAME=claude-3-5-sonnet-latest

# Maximum tokens for generated report output
GENERATION__MAX_TOKENS=2048

# Temperature for generation randomness
GENERATION__TEMPERATURE=0.2
